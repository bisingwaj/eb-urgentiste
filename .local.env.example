# Copier vers .local.env et remplir (fichier ignoré par Git)
#   cp .local.env.example .local.env
#
# Chaque dev / CI : un seul fichier local, aucun secret dans Git (ni Info.plist, ni Android).
# Metro charge .local.env au démarrage (voir metro.config.js + env-bootstrap.js).
#
# EAS Build (cloud) : .local.env n’est pas uploadé. Définir les mêmes EXPO_PUBLIC_* dans
# https://expo.dev → Projet → Environment variables (par environnement / profil de build).
#
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_MAPBOX_TOKEN=
EXPO_PUBLIC_AGORA_APP_ID=
