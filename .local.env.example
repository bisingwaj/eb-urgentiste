# Copier vers .local.env et remplir (fichier ignoré par Git)
# Pour EAS Build (APK/AAB) : définir les mêmes clés EXPO_PUBLIC_* dans Expo → Environment variables
# pour le profil utilisé (ex. preview), car .local.env n’est pas envoyé sur les serveurs de build.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_MAPBOX_TOKEN=
EXPO_PUBLIC_AGORA_APP_ID=
