{
  "expo": {
    "name": "apps-v2",
    "slug": "apps-v2",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.eburgentiste.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio",
          "remote-notification"
        ],
        "NSMicrophoneUsageDescription": "L'application utilise le micro pour les appels avec la centrale de régulation.",
        "NSCameraUsageDescription": "La caméra est utilisée pour les appels vidéo avec la centrale et pour photographier le terrain lors des interventions.",
        "NSFaceIDUsageDescription": "L'application utilise Face ID pour déverrouiller l'accès après connexion."
      }
    },
    "android": {
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.USE_FULL_SCREEN_INTENT",
        "android.permission.WAKE_LOCK"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0D0D"
      },
      "edgeToEdgeEnabled": true,
      "statusBar": {
        "hidden": true
      },
      "navigationBar": {
        "visible": "sticky-immersive"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.eburgentiste.app",
      "versionCode": 12
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "Nécessaire pour les appels vidéo d'urgence.",
          "microphonePermission": "Nécessaire pour communiquer avec les victimes."
        }
      ],
      "expo-build-properties",
      [
        "expo-image-picker",
        {
          "photosPermission": "L'application accède à la galerie pour joindre des photos au dossier d'intervention.",
          "cameraPermission": "La caméra permet de photographier le terrain pour documenter l'intervention."
        }
      ],
      "@react-native-community/datetimepicker",
      "@rnmapbox/maps",
      "expo-secure-store",
      "./plugins/with-notifee-repository",
      "./plugins/with-ndk-config",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "L'application utilise Face ID pour déverrouiller l'accès après connexion."
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/sounds/alarm_alert.wav",
            "./assets/sounds/incoming_call_ring.wav"
          ],
          "defaultChannel": "incoming_calls",
          "enableBackgroundRemoteNotifications": true
        }
      ]
    ],
    "extra": {}
  }
}