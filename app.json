{
  "expo": {
    "name": "apps-v2",
    "slug": "apps-v2",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#050505"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.eburgentiste.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "L'application utilise le micro pour les appels avec la centrale de régulation.",
        "NSCameraUsageDescription": "La caméra est utilisée pour les appels vidéo avec la centrale.",
        "NSFaceIDUsageDescription": "L'application utilise Face ID pour déverrouiller l'accès après connexion."
      }
    },
    "android": {
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#050505"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.eburgentiste.app",
      "versionCode": 2
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@rnmapbox/maps",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "L'application utilise Face ID pour déverrouiller l'accès après connexion."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f8b5d6a4-d96d-44cf-9c3d-1c9c4d225377"
      }
    }
  }
}
