  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "postinstall": "patch-package",
    "prebuild:android": "expo prebuild --platform android --clean",
    "prebuild:check": "expo doctor && tsc --noEmit",
    "test": "jest",
